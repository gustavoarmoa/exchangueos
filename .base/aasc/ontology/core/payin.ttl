@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix exos:   <http://exchangeos.revenu.tech/ontology/payin#> .
@prefix exosc:  <http://exchangeos.revenu.tech/ontology/cls_settlement#> .

<http://exchangeos.revenu.tech/ontology/payin>
    a owl:Ontology ;
    owl:versionIRI <http://exchangeos.revenu.tech/ontology/payin/1.2.0> ;
    owl:versionInfo "1.2.0" ;
    dct:title "ExchangeOS PayIn Ontology"@en, "Ontologia de PayIn"@pt .

exos:PayInInstruction a owl:Class ;
    rdfs:label "Pay-In Instruction"@en, "Instrução de PayIn"@pt .

exos:PayInStatus a owl:Class .
exos:Pending   a exos:PayInStatus ; rdfs:label "PENDING"@en .
exos:Submitted a exos:PayInStatus ; rdfs:label "SUBMITTED"@en .
exos:Confirmed a exos:PayInStatus ; rdfs:label "CONFIRMED"@en .
exos:Failed    a exos:PayInStatus ; rdfs:label "FAILED"@en .

exos:belongsToCycle a owl:ObjectProperty ;
    rdfs:domain exos:PayInInstruction ;
    rdfs:range  exosc:CLSCycle .

exos:hasAmount a owl:DatatypeProperty ;
    rdfs:domain exos:PayInInstruction ; rdfs:range xsd:decimal .

exos:hasDeadline a owl:DatatypeProperty ;
    rdfs:domain exos:PayInInstruction ; rdfs:range xsd:dateTime .
