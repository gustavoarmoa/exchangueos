# ExchangeOS — local dev env (copy to .env, NEVER commit .env with real secrets)
# Production secrets MUST come from Vault SPI — env vars are dev-only.

# ───────────────────────────────────────────────
# Service
# ───────────────────────────────────────────────
EXCHANGEOS_ENV=dev
EXCHANGEOS_HTTP_PORT=8094
EXCHANGEOS_GRPC_PORT=9094

# ───────────────────────────────────────────────
# gRPC
# ───────────────────────────────────────────────
EXCHANGEOS_GRPC_MAX_RECV=16777216
EXCHANGEOS_GRPC_MAX_SEND=16777216
EXCHANGEOS_GRPC_REFLECTION=true

# ───────────────────────────────────────────────
# Database — local compose (NEVER --insecure in prod; use shared CRDB hub TLS)
# ───────────────────────────────────────────────
EXCHANGEOS_DB_DSN=postgres://exchangeos_app@localhost:26257/exchangeos?sslmode=disable
EXCHANGEOS_DB_MAX_CONN=25
EXCHANGEOS_DB_MIN_CONN=2

# ───────────────────────────────────────────────
# Repository backend selector — memory (default) or postgres
# memory: in-memory bootstrap repos (no DB required; default for tests/dev)
# postgres: pgx/v5 repos against EXCHANGEOS_DB_DSN
# ───────────────────────────────────────────────
EXCHANGEOS_REPO_BACKEND=memory

# ───────────────────────────────────────────────
# OpenTelemetry
# ───────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# ───────────────────────────────────────────────
# Kafka (Redpanda) — local
# ───────────────────────────────────────────────
EXCHANGEOS_KAFKA_BROKERS=localhost:9092

# ───────────────────────────────────────────────
# Identos / KeycloakOS (M2M OAuth2 client_credentials)
# In production: client_secret pulled from Vault SPI — NEVER hard-coded.
# ───────────────────────────────────────────────
EXCHANGEOS_OIDC_ISSUER=http://localhost:8084/realms/revenu
EXCHANGEOS_OIDC_CLIENT_ID=exchangeos-api
# EXCHANGEOS_OIDC_CLIENT_SECRET=  # Vault SPI in prod
