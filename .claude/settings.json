{
  "$schema": "https://docs.claude.com/schema/settings.json",
  "model": "claude-opus-4-7",
  "cleanupPeriodDays": 30,
  "includeCoAuthoredBy": true,
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": ".claude/scripts/statusline.sh",
    "padding": 1
  },
  "env": {
    "EXCHANGEOS_PROJECT_ROOT": "/Users/guga/projects/revenu-tech/revenu-platform/exchangeos",
    "EXCHANGEOS_MODULE": "exchangeos",
    "CRDB_HUB_PATH": "../cockroachdb",
    "LEFTHOOK_QUIET": "skips,success",
    "DOCKER_BUILDKIT": "1",
    "COMPOSE_DOCKER_CLI_BUILD": "1",
    "GO_VERSION": "1.25"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "../cockroachdb",
      "../ledgeros",
      "../paymentos",
      "../authorityos",
      "../accountos",
      "../identos",
      "../keycloakos"
    ],
    "allow": [
      "Bash(go test*)",
      "Bash(go build*)",
      "Bash(go vet*)",
      "Bash(go run*)",
      "Bash(go fmt*)",
      "Bash(go mod*)",
      "Bash(go install*)",
      "Bash(go generate*)",
      "Bash(golangci-lint*)",
      "Bash(gosec*)",
      "Bash(govulncheck*)",
      "Bash(gofumpt*)",
      "Bash(goimports*)",
      "Bash(gotestsum*)",
      "Bash(buf*)",
      "Bash(redocly*)",
      "Bash(asyncapi*)",
      "Bash(make *)",
      "Bash(make)",
      "Bash(task *)",
      "Bash(task)",
      "Bash(lefthook*)",
      "Bash(pre-commit*)",
      "Bash(docker compose *)",
      "Bash(docker *)",
      "Bash(helm *)",
      "Bash(helmfile *)",
      "Bash(kubectl *)",
      "Bash(terraform *)",
      "Bash(tflint*)",
      "Bash(tfsec*)",
      "Bash(checkov*)",
      "Bash(trivy*)",
      "Bash(grype*)",
      "Bash(syft*)",
      "Bash(cosign*)",
      "Bash(hadolint*)",
      "Bash(actionlint*)",
      "Bash(yamllint*)",
      "Bash(shellcheck*)",
      "Bash(gitleaks*)",
      "Bash(osv-scanner*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(git remote*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git tag*)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(curl *)",
      "Bash(tree *)",
      "Bash(pyshacl*)",
      "Bash(./scripts/*)",
      "Bash(./tools/*)",
      "Bash(./tests/scripts/*)",
      "Bash(.claude/scripts/*)",
      "Bash(.claude/hooks/*)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .*)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(* | sh)",
      "Bash(* | bash)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git commit --no-verify*)",
      "Bash(git push --no-verify*)",
      "Bash(git reset --hard*)",
      "Bash(eval *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)"
    ],
    "ask": [
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(kubectl delete*)",
      "Bash(terraform destroy*)",
      "Bash(terraform apply*)",
      "Bash(helm delete*)",
      "Bash(helm uninstall*)",
      "Bash(git tag -d*)",
      "Bash(git branch -D*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/session-start.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/user-prompt-submit.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/pre-bash.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/pre-write.sh" }
        ]
      },
      {
        "matcher": "mcp__*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/on-mcp-call.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/on-file-save.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/post-bash.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/session-stop.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/subagent-stop.sh" }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/notification.sh" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/session-end.sh" }
        ]
      }
    ]
  }
}
